page{ background:#f2f5f9; }
.page{ height:100vh; padding:24rpx; box-sizing:border-box; }
.card{ background:#fff; border-radius:20rpx; padding:24rpx; margin-bottom:16rpx; }
.title{ font-size:30rpx; font-weight:600; color:#1b2a41; margin-bottom:12rpx; }
.field{ margin-bottom:10rpx; }
.label{ display:block; font-size:22rpx; color:#60708a; margin-bottom:6rpx; }
.picker-view{ background:#f7faff; border-radius:12rpx; padding:12rpx; font-size:24rpx; color:#223652; }
.row-inline{ display:flex; align-items:center; justify-content:space-between; margin:12rpx 0; }
.label-inline{ font-size:22rpx; color:#60708a; }
.tip{ font-size:21rpx; color:#5b6d87; margin-top:10rpx; }
input{ background:#f7faff; border-radius:12rpx; padding:12rpx; font-size:24rpx; color:#223652; }
.op-box{ background:#f7faff; border-radius:14rpx; padding:12rpx; margin-bottom:12rpx; }
.op-title{ display:block; font-size:22rpx; color:#495972; margin-bottom:8rpx; }
.group-row{ margin-top:6rpx; display:flex; gap:10rpx; flex-wrap:wrap; }
.group-chip{ padding:8rpx 18rpx; border-radius:999rpx; background:#e9edf5; color:#495972; font-size:22rpx; }
.group-chip.active{ background:#1f6feb; color:#fff; }
.head-row{ display:flex; justify-content:space-between; align-items:center; }
.name{ font-size:28rpx; font-weight:600; color:#1d3358; }
.id{ margin-top:4rpx; font-size:21rpx; color:#6d7a8e; }
.status{ font-size:22rpx; padding:6rpx 12rpx; border-radius:999rpx; }
.status.online{ color:#16a34a; background:#e8fbe8; }
.status.offline{ color:#dc2626; background:#feecec; }
.meta{ margin-top:8rpx; font-size:22rpx; color:#52637d; }
.actions{ margin-top:14rpx; display:flex; gap:10rpx; flex-wrap:wrap; }
.bind-btn{ background:#1f6feb; color:#fff; border-radius:12rpx; }
.warning-btn{ background:#eef4ff; color:#1f6feb; border-radius:12rpx; }
.danger-btn{ background:#fee2e2; color:#b91c1c; border-radius:12rpx; }
.debug-text{ display:block; white-space:pre-wrap; word-break:break-all; font-size:20rpx; color:#334155; background:#f8fafc; padding:12rpx; border-radius:10rpx; }
