<view class="page">
  <view class="card">
    <view class="title">自动刷新配置</view>
    <view class="row">
      <text>默认开启自动刷新</text>
      <switch checked="{{enabled}}" bindchange="onToggle" color="#1f6feb" />
    </view>
    <view class="field">
      <text class="label">刷新间隔（秒）</text>
      <input type="number" value="{{intervalSec}}" bindinput="onInputInterval" />
    </view>
    <button class="btn" bindtap="saveConfig">保存</button>
  </view>
</view>
