page{background:#f2f5f9}
.page{height:100vh;padding:24rpx;box-sizing:border-box}
.card{background:#fff;border-radius:20rpx;padding:24rpx;margin-bottom:16rpx}
.title{font-size:30rpx;font-weight:600;color:#1b2a41;margin-bottom:10rpx}
.meta{font-size:22rpx;color:#52637d;margin-top:6rpx}
.row{display:flex;justify-content:space-between;align-items:center;margin-top:12rpx}
.item{background:#f7faff;border-radius:12rpx;padding:12rpx;margin-top:10rpx}
.name{font-size:24rpx;color:#1d3358;font-weight:600}
.value{font-size:32rpx;color:#0f1f38;font-weight:700;margin-top:4rpx}
.btn{margin-top:12rpx;background:#1f6feb;color:#fff;border-radius:12rpx}
