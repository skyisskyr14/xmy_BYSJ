<scroll-view class="page" scroll-y enable-flex>
  <view class="hero card">
    <view class="hero-title">{{projectName}}</view>
    <view class="hero-subtitle">{{subtitle}}</view>
    <view class="hero-time">最近更新：{{updateTime}}</view>
    <view class="hero-hint">{{connectionHint}}</view>
  </view>

  <view class="card section">
    <view class="section-title">设备信息</view>
    <view class="device-grid">
      <view class="item">
        <text class="label">设备编号</text>
        <text class="value">{{device.id}}</text>
      </view>
      <view class="item">
        <text class="label">部署位置</text>
        <text class="value">{{device.location}}</text>
      </view>
      <view class="item">
        <text class="label">在线状态</text>
        <text class="value status online">{{device.status}}</text>
      </view>
      <view class="item">
        <text class="label">信号质量</text>
        <text class="value">{{device.signal}}</text>
      </view>
      <view class="item">
        <text class="label">电量</text>
        <text class="value">{{device.battery}}%</text>
      </view>
    </view>
  </view>

  <view class="section-title split-title">水质核心指标</view>
  <view class="metrics-wrap">
    <block wx:for="{{metrics}}" wx:key="key">
      <view class="card metric-card">
        <view class="metric-head">
          <text class="metric-name">{{item.title}}</text>
          <text class="metric-level">{{item.level}}</text>
        </view>
        <view class="metric-value-row">
          <text class="metric-value">{{item.value}}</text>
          <text class="metric-unit">{{item.unit}}</text>
        </view>
        <view class="metric-desc">{{item.desc}}</view>
        <view class="metric-trend">{{item.trend}}</view>
      </view>
    </block>
  </view>

  <view class="card section">
    <view class="section-title">后续功能规划</view>
    <view class="quick-list">
      <block wx:for="{{quickActions}}" wx:key="title">
        <view class="quick-item">
          <view class="quick-title">{{item.title}}</view>
          <view class="quick-tip">{{item.tip}}</view>
        </view>
      </block>
    </view>
  </view>
</scroll-view>
