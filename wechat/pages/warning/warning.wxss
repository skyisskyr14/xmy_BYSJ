page{ background:#f2f5f9; }
.page{ height:100vh; padding:24rpx; box-sizing:border-box; }
.card{ background:#fff; border-radius:20rpx; padding:24rpx; margin-bottom:18rpx; }
.title{ font-size:30rpx; font-weight:600; color:#1b2a41; }
.subtitle{ margin-top:8rpx; font-size:22rpx; color:#60708a; }
.device-scroll{ white-space:nowrap; margin-top:12rpx; }
.device-chip-wrap{ display:inline-flex; gap:12rpx; padding-bottom:4rpx; }
.device-chip{ min-width:220rpx; background:#fff; border:1px solid #d9e7ff; border-radius:16rpx; padding:12rpx 14rpx; }
.device-chip.active{ background:#1f6feb; border-color:#1f6feb; }
.chip-name{ display:block; font-size:24rpx; font-weight:600; color:#173158; }
.chip-id{ display:block; margin-top:6rpx; font-size:20rpx; color:#60708a; }
.device-chip.active .chip-name,.device-chip.active .chip-id{ color:#fff; }
.row{ display:flex; justify-content:space-between; align-items:center; padding:10rpx 0; }
.rule-box{ background:#f7faff; border-radius:14rpx; padding:16rpx; margin-bottom:12rpx; }
.rule-name{ font-size:26rpx; font-weight:600; color:#1d3358; }
.input-row{ display:flex; gap:12rpx; margin-top:12rpx; }
.input-box{ flex:1; background:#fff; border-radius:10rpx; padding:10rpx; }
.mini{ font-size:20rpx; color:#6b7a92; }
input{ margin-top:6rpx; font-size:24rpx; color:#223652; }
.save-btn{ background:#1f6feb; color:#fff; border-radius:16rpx; }
